# Copiar a /etc/yeyo-agents.env o a .yeyo-agents/config/local.env en desarrollo.
YEYO_ROOT=/srv/yeyo
YEYO_DOCUMENT_DB=/srv/yeyo/.yeyo-memory/sqlite/yeyo-memory.sqlite
YEYO_AGENT_DB=/srv/yeyo/.yeyo-agents/data/agents.sqlite
YEYO_APP_NAME=Gestión Documental
YEYO_MAX_CONTEXT_CHUNKS=8
YEYO_MAX_CONTEXT_CHARS=14000

# Opcional. Si no se configura, el sistema responde en modo extractivo local.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Token de administración por defecto para accesos automáticos
YEYO_ADMIN_TOKEN=yeyo_admin_token
